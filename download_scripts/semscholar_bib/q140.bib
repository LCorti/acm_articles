	author = {David Silver and Julian Schrittwieser and K. Simonyan and Ioannis Antonoglou and Aja Huang and A. Guez and T. Hubert and Lucas baker and Matthew Lai and A. Bolton and Yutian Chen and T. Lillicrap and Fan Hui and L. Sifre and George van den Driessche and T. Graepel and D. Hassabis},
