@misc{pop00003,
	author = {Muhammad Abdullah Hanif and Faiq Khalid and Rachmad Vidya Wicaksana Putra and M. Teimoori and F. Kriebel and Jeff Zhang and Kang Liu and Semeen Rehman and T. Theocharides and A. Artusi and S. Garg and M. Shafique},
	title = {Robust Computing for Machine Learning-Based Systems},
	doi = {10.1007/978-3-030-52017-5_20},
