	doi = {10.1111/j.1934-6093.2002.tb00084.x},
	year = {2002},
	abstract = {In this paper, we propose a robust PID controller tuning method for parametric uncertainty systems (or interval plant family) using fuzzy neural networks (FNNs). This robust controller is based on robust gain and phase margin (GM/PM) specifications that satisfy user requirements. Here, the FNN system is used to identify the relation between the PID controller parameters and robust GM/PM. We can use the trained FNN system to determine the parameters of the PID controllers in order to satisfy robust GM/PM specifications that guarantee robustness and performance. Simulation results are shown to illustrate the effectiveness of the robust controller scheme.},
