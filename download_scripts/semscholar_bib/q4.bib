@misc{pop00011,
	author = {Yue Zhao},
	title = {Decision Support System for Economic Management of Large Enterprises Based on Artificial Intelligence},
	doi = {10.1155/2022/9453580},
	year = {2022},
	abstract = {In order to improve the economic management effect of large enterprises, a decision support system for economic management of large enterprises based on artificial intelligence is designed. The system hardware and software are designed, respectively. The system hardware consists of basic information module, business management module, personnel management module, salary and welfare management module, system management module, and database module. With the support of artificial intelligence technology, build a BP neural network model, and the model was trained, through continuous learning rate adjustment; in the process of training error lower sales forecast results, according to the result of prediction in enterprise comprehensive benefit maximization as the goal, set up large enterprises economic management decision-making model, large enterprise economic management decision-making algorithm design. The test results show that the system has good fault tolerance, reliability, robustness, and high efficiency, the system response time is short, the decision accuracy is high, and the practical application effect is good.},
