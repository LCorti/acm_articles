@misc{pop00012,
	author = {FarzinPiltan and MarziehKamgari and SaeedZare and FatemehShahryarZadeh and M. Mansoorzadeh},
	title = {Design Novel Model Reference Artificial Intelligence Based Methodology to Optimized Fuel Ratio in IC Engine},
