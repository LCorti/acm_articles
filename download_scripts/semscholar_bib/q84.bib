@misc{pop00172,
	author = {Lin Li and Lixin Qin and Zeguo Xu and Youbing Yin and Xin Wang and Bin Kong and Junjie Bai and Yi Lu and Zhenghan Fang and Q. Song and K. Cao and Daliang Liu and Guisheng Wang and Qizhong Xu and Xisheng Fang and Shiqin Zhang and J. Xia and Jun Xia},
