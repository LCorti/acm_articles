	author = {C. Ananth and M. Karthikeyan and N. Mohananthini},
	title = {Discrete Wavelet Transform Based Multiple Watermarking for Digital Images Using Back-Propagation Neural Network},
	doi = {10.1007/978-3-030-33846-6_49},
