	abstract = {We present the state-of-art study of a recent emerging research area named as Adversarial Machine Learning, it investigates the vulnerabilities of current learning algorithms from the perspective of an adversary. We show that several state-of-art learning systems are intrinsically vulnerable under carefully designed adversarial attacks. Moreover, we suggest countermeasures against adversarial actions, which inspire discussion of constructing more secure and robust learning algorithms.},
