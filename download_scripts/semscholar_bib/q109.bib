	author = {Stefano Calzavara and C. Lucchese and Federico Marcuzzi and S. Orlando},
	title = {Feature partitioning for robust tree ensembles and their certification in adversarial scenarios},
	doi = {10.1186/s13635-021-00127-0},
	year = {2020},
	note = {4 cites: },
