@misc{pop00144,
	author = {Seung-Jean Kim and Stephen P. Boyd},
	title = {A minimax theorem with applications to machine learning, signal processing, and finance},
	doi = {10.1137/060677586},
	year = {2007},
	abstract = {This paper concerns a fractional function of the form xTalpha/radicxTBx, where B is positive definite. We consider the game of choosing x from a convex set, to maximize the function, and choosing (alpha, B) from a convex set, to minimize it. We prove the existence of a saddle point and describe an efficient method, based on convex optimization, for computing it. We describe applications in machine learning (robust Fisher linear discriminant analysis), signal processing (robust beam- forming, robust matched filtering), and finance (robust portfolio selection). In these applications, x corresponds to some design variables to be chosen, and the pair (alpha, B) corresponds to the statistical model, which is uncertain.},
	note = {57 cites: },
