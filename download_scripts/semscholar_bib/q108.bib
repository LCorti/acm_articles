	author = {D. Ramík and C. Sabourin and R. Moreno and K. Madani},
	title = {A machine learning based intelligent vision system for autonomous object detection and recognition},
	doi = {10.1007/s10489-013-0461-5},
	year = {2014},
	note = {66 cites: },
