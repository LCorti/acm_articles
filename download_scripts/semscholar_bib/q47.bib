	author = {Yannick Suter and U. Knecht and Mariana Alão and W. Valenzuela and E. Hewer and P. Schucht and R. Wiest and M. Reyes},
	title = {Radiomics for glioblastoma survival analysis in pre-operative MRI: exploring feature robustness, class boundaries, and machine learning techniques},
