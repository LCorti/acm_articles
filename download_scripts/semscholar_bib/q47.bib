	author = {S. Ardabili and A. Mosavi and A. Várkonyi-Kóczy},
	title = {Advances in Machine Learning Modeling Reviewing Hybrid and Ensemble Methods},
	doi = {10.1007/978-3-030-36841-8_21},
	year = {2019},
