@misc{pop00178,
	author = {A. Garcez and Tarek R. Besold and L. D. Raedt and P. Földiák and P. Hitzler and Thomas F. Icard and Kai-Uwe Kühnberger and L. Lamb and R. Miikkulainen and D. Silver},
