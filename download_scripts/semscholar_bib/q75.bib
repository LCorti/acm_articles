	author = {V. Nguyen and A. Vo and Hee-Jun Kang},
	title = {Continuous PID Sliding Mode Control Based on Neural Third Order Sliding Mode Observer for Robotic Manipulators},
	doi = {10.1007/978-3-030-26766-7_16},
