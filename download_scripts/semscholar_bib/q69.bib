	author = {Qinmin Yang and Zaiyue Yang and Youxian Sun},
	title = {Universal Neural Network Control of MIMO Uncertain Nonlinear Systems},
	doi = {10.1109/TNNLS.2012.2197219},
	year = {2012},
	abstract = {In this brief, a continuous tracking control law is proposed for a class of high-order multi-input-multi-output uncertain nonlinear dynamic systems with external disturbance and unknown varying control direction matrix. The proposed controller consists of high-gain feedback, Nussbaum gain matrix selector, online approximator (OLA) model and a robust term. The OLA model is represented by a two-layer neural network. The continuousness of the control signal is guaranteed to relax the requirement for the actuator bandwidth and avoid the incurred chattering effect. Asymptotic tracking performance is achieved theoretically by standard Lyapunov analysis. The control feasibility is also verified in simulation environment.},
