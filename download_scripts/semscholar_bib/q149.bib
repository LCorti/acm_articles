@misc{pop00009,
	author = {J. Vitay},
	title = {Re ] Robust timing and motor patterns by taming chaos in recurrent neural networks},
	year = {2016},
	abstract = {Recurrent neural networks have the capacity to exhibit complex spatio-temporal patterns that can be used to produce motor patterns. The research field of reservoir computing [2, 4] focuses on forcing recurrent networks to produce a desired read-out output through supervised learning. In the high-gain regime, recurrent networks can even exhibit rich and complex patterns in the absence of stimulation, but they become chaotic, as they can not reproduce twice the same trajectory in the presence of noise [5]. In Laje and Buonomano [3], the authors proposed a method to tame the chaos in such networks, by training the recurrent weights to minimize the error between a desired trajectory spontaneously generated by the network in an initial trial and the current trajectory. By selectively creating stable dynamic attractors, this method allows to benefit at the same time from the rich dynamics of a chaotic network and from the reproducibility of a deterministic one.},
	note = {1 cites: },
	note = {Query date: 2022-07-13 10:28:37},
}
