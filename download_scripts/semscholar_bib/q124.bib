	author = {M. Alber and A. Buganza Tepole and W. R. Cannon and S. De and S. Dura-Bernal and K. Garikipati and G. Karniadakis and W. Lytton and P. Perdikaris and L. Petzold and E. Kuhl},
	title = {Integrating machine learning and multiscale modeling—perspectives, challenges, and opportunities in the biological, biomedical, and behavioral sciences},
