@misc{pop00183,
	author = {Tamer Karatekin and S. Sancak and G. Celik and S. Topçuoğlu and G. Karatekin and Pınar Kırcı and A. Okatan},
	title = {Interpretable Machine Learning in Healthcare through Generalized Additive Model with Pairwise Interactions (GA2M): Predicting Severe Retinopathy of Prematurity},
