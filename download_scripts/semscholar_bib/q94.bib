@misc{pop00079,
	author = {Chao Fang and Zhengfeng Li and Ying Xue and Zheng You},
	title = {Research on Innovation Path of Artificial Intelligence Technology Based on Comparative Analysis},
	doi = {10.15302/j-sscae-2020.04.021},
	year = {2020},
	abstract = {Currently, artificial intelligence (AI) technology has been widely applied in socio-economic development and national defense construction; however, it still requires improvement in terms of flexibility, interpretability, robustness, and security. This study defines AI technology and AI industry and subsequently compares AI technology with nuclear and photovoltaic technologies from the aspects of basic theory, technology development, and market application, aiming to explore an effective path for AI development and innovation. The study reveals that the development of AI technology is bound to shift from an involution to evolution mode and integrated development is an optimized path for AI technology innovation in China. Specifically, a three-step development route should be adopted, including direct transfer of civilian achievements to military use, military–civilian coordinated innovation, and promoting civilian use based on military development. To promote deep integration of AI technology, new research institutions should be established, financial support be increased, talent training be promoted, and ethical research be conducted.},
