@misc{pop00131,
	author = {Nikos Tsiknakis and Eleftherios Trivizakis and Evangelia E Vassalou and G. Papadakis and D. Spandidos and A. Tsatsakis and J. Sánchez-García and R. López-González and N. Papanikolaou and A. Karantanas and K. Marias},
	title = {Interpretable artificial intelligence framework for COVID-19 screening on chest X-rays},
