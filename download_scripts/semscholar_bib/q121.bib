	author = {Fahad Shabbir Ahmad and Liaqat Ali and Liaqat Ali and Raza-Ul-Mustafa and Hasan Ali Khattak and Tahir Hameed and Iram Wajahat and Seifedine Kadry and S. Bukhari},
	title = {A hybrid machine learning framework to predict mortality in paralytic ileus patients using electronic health records (EHRs)},
