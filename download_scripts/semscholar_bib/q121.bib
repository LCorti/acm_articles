	author = {G. Peng and M. Alber and A. Buganza Tepole and W. R. Cannon and S. De and Savador Dura-Bernal and K. Garikipati and G. Karniadakis and W. Lytton and P. Perdikaris and L. Petzold and E. Kuhl},
	title = {Multiscale modeling meets machine learning: What can we learn?},
