@misc{pop00025,
	author = {Ashkan Khakzar and Shadi Albarqouni and Nassir Navab},
	title = {Learning Interpretable Features via Adversarially Robust Optimization},
	doi = {10.1007/978-3-030-32226-7_88},
	year = {2019},
