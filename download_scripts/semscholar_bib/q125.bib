@misc{pop00007,
	author = {B. Vasey and Stephan Ursprung and Benjamin Beddoe and E. Taylor and N. Marlow and N. Bilbro and P. Watkinson and P. McCulloch},
	title = {Association of Clinician Diagnostic Performance With Machine Learning–Based Decision Support Systems},
