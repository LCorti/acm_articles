@misc{pop00138,
	author = {S. Zarrabian},
	title = {Temporal difference-based approach for adaptive cascading outages alleviation and stability improvement in bulk power systems},
	doi = {10.1109/PESGM.2017.8274439},
	year = {2017},
	abstract = {Temporal Difference (TD) as a powerful approach is a well-known reinforcement learning (RL) method based on machine learning concept. Bulk power systems with sophisticated traditional controls and low reliability are suffering extremely from instability and cascading events followed by a single fault in transmission lines or loss of generation and loads. This paper proposes a novel approach based on temporal difference to alleviate effect of cascading events and enhance the voltage and angular stability in bulk power systems even after multiple contingencies. This TD-based approach is implemented as a complementary control to the AGC units and obtains optimal action policy for accurate tuning of generated output power through a state-action learning process by updating the policy based on the received rewards. The proposed intelligent control is validated by dynamic simulation on the IEEE 118-bus system for multiple case studies. The results show the accuracy and robustness of the proposed approach.},
	note = {1 cites: },
	note = {Query date: 2022-07-13 10:19:15},
}
