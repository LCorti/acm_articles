@misc{pop00008,
	author = {Meletios Doulgkeroglou and Alessia Di Nubila and B. Nießing and N. König and R. Schmitt and J. Damen and S. Szilvassy and W. Chang and L. Csontos and S. Louis and P. Kugelmeier and V. Ronfard and Y. Bayon and D. Zeugolis},
	title = {Automation, Monitoring, and Standardization of Cell Product Manufacturing},
