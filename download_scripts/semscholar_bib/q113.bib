	author = {Stuart J. Russell},
	title = {Artificial Intelligence and the Problem of Control},
	doi = {10.1007/978-3-030-86144-5_3},
	year = {2021},
	note = {4 cites: },
	note = {Query date: 2022-07-13 10:25:35},
